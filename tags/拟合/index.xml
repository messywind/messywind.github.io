 &lt;div class="details-summary admonition-title">&lt;i class="icon fa-fw fa-solid fa-circle-info" aria-hidden="true">&lt;/i>结论&lt;i class="details-icon fa-solid fa-angle-right fa-fw" aria-hidden="true">&lt;/i>&lt;/div>
 &lt;div class="details-content">
 &lt;div class="admonition-content">&lt;p>$$
y = 29.11 \log(x + 170.83) - 149.86
$$&lt;/p>
&lt;div class="calc">
 &lt;input type="text" id="inputValue" placeholder="输入护甲值">
&lt;p>&lt;button onclick="calculate()">计算&lt;/button>&lt;/p>
 &lt;p id="result"/>
&lt;/div>
&lt;script>
 document.getElementById('inputValue').addEventListener('input', function (e) {
 this.value = this.value.replace(/[^0-9]/g, '');
 });

 function calculate() {
 var x = parseInt(document.getElementById('inputValue').value);
 if (!isNaN(x) &amp;&amp; x > 0) {
 var y = 29.11 * Math.log(x + 170.83) - 149.86;
 document.getElementById('result').innerHTML = "承伤百分比：" + y.toFixed(2) + "%";
 } else {
 document.getElementById('result').innerHTML = "请输入有效的正整数。";
 }
 }
&lt;/script>
